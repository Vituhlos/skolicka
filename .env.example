# Rodičovský PIN — bcrypt hash
# Vygeneruj: docker run --rm node:22-alpine node -e "require('bcrypt').hash('1234',10).then(h=>console.log(h))"
PARENT_PIN_HASH=$2b$10$replacethiswithrealhash

# JWT secret — libovolný dlouhý náhodný řetězec (min. 32 znaků)
# Vygeneruj: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-string
